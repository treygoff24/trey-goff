{
  "name": "trey-goff",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "covers": "tsx scripts/resolve-book-covers.ts && tsx scripts/resolve-appearance-covers.ts",
    "prebuild": "tsx scripts/resolve-book-covers.ts && tsx scripts/resolve-appearance-covers.ts && tsx scripts/generate-search-index.ts && tsx scripts/generate-interactive-manifests.ts && tsx scripts/compress-assets.ts",
    "generate-manifests": "tsx scripts/generate-interactive-manifests.ts",
    "build": "next build",
    "postbuild": "tsx scripts/validate-asset-budgets.ts && tsx scripts/check-bundle-isolation.ts",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "typecheck:ts7": "pnpm typecheck:ts7:scoped",
    "typecheck:ts7:scoped": "tsgo -p tsconfig.ts7.json --noEmit",
    "typecheck:ts7:full": "tsgo --noEmit",
    "tsgo": "tsgo",
    "typecheck:ts7": "pnpm typecheck:ts7:scoped",
    "typecheck:ts7:scoped": "tsgo -p tsconfig.ts7.json --noEmit",
    "typecheck:ts7:full": "tsgo --noEmit",
    "tsgo": "tsgo",
    "test": "node --import tsx --test test/*.test.ts",
    "test:coverage": "c8 --reporter=text --reporter=lcov node --import tsx --test test/*.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:chromium": "playwright test --project=chromium",
    "generate-search": "tsx scripts/generate-search-index.ts",
    "compress-assets": "tsx scripts/compress-assets.ts",
    "validate-budgets": "tsx scripts/validate-asset-budgets.ts",
    "check-bundle-isolation": "tsx scripts/check-bundle-isolation.ts"
  },
  "dependencies": {
    "@content-collections/core": "^0.14.2",
    "@content-collections/next": "^0.2.11",
    "@orama/orama": "^3.1.18",
    "@radix-ui/react-dialog": "^1.1.15",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/postprocessing": "^3.0.4",
    "@react-three/rapier": "^2.2.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "ecctrl": "^1.0.97",
    "feed": "^5.2.0",
    "framer-motion": "^12.35.2",
    "graphology": "^0.26.0",
    "graphology-layout-forceatlas2": "^0.10.1",
    "graphology-types": "^0.24.8",
    "lucide-react": "^0.577.0",
    "next": "^16.1.6",
    "postprocessing": "^6.38.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "sigma": "^3.0.2",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.2",
    "three-pathfinding": "^1.3.0",
    "three-stdlib": "^2.36.1",
    "unified": "^11.0.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@gltf-transform/cli": "^4.3.0",
    "@gltf-transform/extensions": "^4.3.0",
    "@gltf-transform/functions": "^4.3.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "@typescript/native-preview": "7.0.0-dev.20260309.1",
    "c8": "^11.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@9.15.1"
}
